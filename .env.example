# Smart Mirror — Environment Variables
# Copy this to .env and fill in your values

# ── Server ───────────────────────────────
PORT=3000

# ── Strava ───────────────────────────────
# Get these from https://www.strava.com/settings/api
# Steps:
#   1. Create an app at strava.com/settings/api
#   2. Set Authorization Callback Domain to: localhost
#   3. Run: node scripts/strava-auth.js  to get your refresh token
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token

# ── Immich ───────────────────────────────
# Your local Immich server URL (no trailing slash)
IMMICH_URL=http://192.168.200.119:2283
# Generate an API key in Immich: Account Settings → API Keys
IMMICH_API_KEY=your_immich_api_key
# The album ID where mirror selfies are stored
# Find it in the Immich URL when viewing the album
IMMICH_ALBUM_ID=your_album_uuid

# ── Motion Sensor (HC-SR501 PIR) ──────────
# GPIO pin (BCM numbering) the PIR sensor's OUT pin is wired to
MOTION_GPIO_PIN=17
# How many seconds after the last detected motion before the mirror goes to sleep
MOTION_GRACE_SECONDS=45
# URL the motion_sensor.py daemon uses to reach this server (usually localhost)
MIRROR_URL=http://localhost:3000

# ── WLED Lighting (ESP32 + WLED firmware) ─
# IP address of your ESP32 running WLED, no trailing slash, no /json suffix
WLED_URL=http://192.168.1.50
# Optional: if you've saved your default lighting look as a WLED preset,
# put its preset ID here so /api/lights/restore can recall it exactly.
# Find preset IDs in the WLED web UI under the Presets tab.
# If left blank, restore just sends {"on": true} and WLED falls back to
# whatever state/effect it was last in before the countdown started.
WLED_DEFAULT_PRESET=

